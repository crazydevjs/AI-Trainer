# ============================================================
# FORGE — Environment Variables (copy to .env and fill in)
# ============================================================

# --- Database (PostgreSQL) ---
# Free options: Neon (neon.tech) or Supabase (supabase.com)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/forge?sslmode=require"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Auth / JWT ---
# Generate with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (SMTP) for verification / password reset ---
# In dev, if SMTP_HOST is empty, links are printed to the server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="FORGE <no-reply@forge.app>"

# --- OpenAI (AI coaching / plan generation) ---
OPENAI_API_KEY=""
